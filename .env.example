# ── Supabase (auth + database) ────────────────────────────────
# Get these from: https://supabase.com → your project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ── AI Providers ───────────────────────────────────────────────
# Groq (free) — transcription + LLM: https://console.groq.com
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxx

# Google Gemini (free) — AI analysis: https://aistudio.google.com/apikey
GEMINI_API_KEY=AIzaSyxxxxxxxxxxxxxxxxxxxxxxxx

# OpenRouter (free models) — fallback LLM: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxx

# ── Upstash Redis (rate limiting + job queue) ──────────────────
# Get from: https://console.upstash.com → Create Database → REST API
UPSTASH_REDIS_REST_URL=https://your-db.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-token-here

# ── Cloudflare R2 (clip file storage) ─────────────────────────
# Get from: https://dash.cloudflare.com → R2 → Manage API Tokens
CLOUDFLARE_R2_ACCOUNT_ID=your-account-id
CLOUDFLARE_R2_ACCESS_KEY_ID=your-access-key
CLOUDFLARE_R2_SECRET_ACCESS_KEY=your-secret-key
CLOUDFLARE_R2_BUCKET_NAME=clipfinder-clips
CLOUDFLARE_R2_PUBLIC_URL=https://pub-xxxx.r2.dev

# ── Modal.com worker (yt-dlp + FFmpeg) ────────────────────────
# Get from: https://modal.com → Settings → API tokens
MODAL_WORKER_URL=https://your-username--clipfinder-worker-web.modal.run
MODAL_API_KEY=ak-xxxxxxxxxxxxxxxxxxxx

# ── LemonSqueezy (subscriptions + billing) ────────────────────
# Get from: https://app.lemonsqueezy.com → Settings → API
LEMONSQUEEZY_API_KEY=eyJ0eXAiOiJKV1Qixxxxx
LEMONSQUEEZY_STORE_ID=12345
LEMONSQUEEZY_WEBHOOK_SECRET=your-webhook-secret
# Product variant IDs from your LemonSqueezy store
LEMONSQUEEZY_PRO_VARIANT_ID=111111
LEMONSQUEEZY_AGENCY_VARIANT_ID=222222

# ── App ────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXTAUTH_SECRET=generate-with-openssl-rand-base64-32
